# Copy this file to `.env` or `.env.local` and fill values. Do NOT commit real secrets.
#
# Deployment: a single Vercel project hosts both the React frontend and the
# serverless API under /api (api/send-otp, api/verify-otp, api/chat).
#
# - VITE_* vars are exposed to the browser (set them in Vercel "Environment Variables").
# - Non-VITE_ vars are server-only (used by the /api functions) and never reach the client.

# ----------------- Frontend (VITE_*, exposed to browser) -----------------
VITE_EMAILJS_SERVICE_ID=service_lryd73h
VITE_EMAILJS_APPT_TEMPLATE_ID=template_r26t8ov   # appointment-confirmation template
VITE_EMAILJS_PUBLIC_KEY=MGrfNH-8tMwQkb0fp

# Leave EMPTY in production so the app calls same-origin /api/*.
# Set this only for local dev when pointing at the deployed API,
# e.g. VITE_BACKEND_URL=https://your-app.vercel.app
VITE_BACKEND_URL=

VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Firebase
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=BUCKET_NAME
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# ----------------- Server-only (used by /api serverless functions) -----------------
# Gemini (chatbot proxy)
GEMINI_API_KEY=YOUR_API_KEY_HERE

# Server-side OTP email via EmailJS REST API.
# In EmailJS: Account -> Security -> enable
#   "Allow EmailJS API for non-browser applications", then copy the Private Key.
EMAILJS_SERVICE_ID=
EMAILJS_OTP_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# Secret that signs OTP challenge + verification tokens. REQUIRED in production
# so tokens stay valid across serverless instances/deploys.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OTP_SECRET=

# Optional: comma-separated origins allowed to call the API cross-origin
# (same-origin requests don't need this). Defaults include localhost + the clinic domains.
ALLOWED_ORIGINS=http://localhost:5173,https://ssclinickudlu.com,https://www.ssclinickudlu.com
