# Backend server environment variables (copy to `backend/.env` and fill values)

GEMINI_API_KEY=
PORT=5000

# Comma-separated list of origins allowed to call this backend
ALLOWED_ORIGINS=http://localhost:5173,https://ssclinickudlu.com,https://www.ssclinickudlu.com

# ---- Server-side OTP email (EmailJS REST API) ----
# In the EmailJS dashboard: Account -> Security ->
#   enable "Allow EmailJS API for non-browser applications"
# and copy your Private Key (access token).
EMAILJS_SERVICE_ID=
EMAILJS_OTP_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# Secret used to hash OTPs and sign verification tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OTP_SECRET=
